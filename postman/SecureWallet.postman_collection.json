{
  "info": { "name": "SecureWallet API", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json" },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    { "name": "Register (valido)", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}],
      "url": "{{base_url}}/auth/register",
      "body": {"mode":"raw","raw":"{\"nombre_completo\":\"Test User\",\"ci\":\"9999999\",\"email\":\"test@demo.com\",\"telefono\":\"71234567\",\"password\":\"Passw0rd!123\",\"captcha_token\":\"demo\"}"} } },
    { "name": "Register (invalido - password debil)", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}],
      "url": "{{base_url}}/auth/register",
      "body": {"mode":"raw","raw":"{\"nombre_completo\":\"Test\",\"ci\":\"888\",\"email\":\"bad\",\"telefono\":\"7\",\"password\":\"123\",\"captcha_token\":\"demo\"}"} } },
    { "name": "Login", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}],
      "url": "{{base_url}}/auth/login",
      "body": {"mode":"raw","raw":"{\"email\":\"usuario1@securewallet.test\",\"password\":\"Usuario1#2026\"}"} } },
    { "name": "Login (fuerza bruta x6)", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}],
      "url": "{{base_url}}/auth/login",
      "body": {"mode":"raw","raw":"{\"email\":\"usuario1@securewallet.test\",\"password\":\"incorrecta\"}"} } },
    { "name": "MFA Verify", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}],
      "url": "{{base_url}}/auth/mfa/verify",
      "body": {"mode":"raw","raw":"{\"mfa_ticket\":\"PEGAR_TICKET\",\"codigo\":\"123456\"}"} } },
    { "name": "Refresh Token", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}],
      "url": "{{base_url}}/auth/refresh",
      "body": {"mode":"raw","raw":"{\"refresh_token\":\"{{refresh_token}}\"}"} } },
    { "name": "Me", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{access_token}}"}], "url": "{{base_url}}/me" } },
    { "name": "Wallet (propio)", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{access_token}}"}], "url": "{{base_url}}/wallet" } },
    { "name": "Top Up", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],
      "url": "{{base_url}}/wallet/topup", "body": {"mode":"raw","raw":"{\"monto\":100}"} } },
    { "name": "Crear Transferencia", "request": { "method": "POST",
      "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
      "url": "{{base_url}}/transfers", "body": {"mode":"raw","raw":"{\"destinatario\":\"usuario2@securewallet.test\",\"monto\":50,\"descripcion\":\"prueba\"}"} } },
    { "name": "Confirmar Transferencia", "request": { "method": "POST",
      "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],
      "url": "{{base_url}}/transfers/PEGAR_UUID/confirm", "body": {"mode":"raw","raw":"{\"confirmar\":true}"} } },
    { "name": "Historial", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{access_token}}"}], "url": "{{base_url}}/transactions?page=1" } },
    { "name": "[Ataque] Wallet ajena por UUID (debe dar 403/404)", "request": { "method": "GET",
      "header": [{"key":"Authorization","value":"Bearer {{access_token}}"}], "url": "{{base_url}}/wallet/OTRO-UUID-INVENTADO" } },
    { "name": "[Admin] Listar usuarios", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{access_token}}"}], "url": "{{base_url}}/admin/users" } },
    { "name": "[Ataque] Admin endpoint con rol USER (debe dar 403)", "request": { "method": "GET",
      "header": [{"key":"Authorization","value":"Bearer {{access_token}}"}], "url": "{{base_url}}/admin/users" } },
    { "name": "[Admin] Bloquear usuario", "request": { "method": "PATCH",
      "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],
      "url": "{{base_url}}/admin/users/PEGAR_UUID/block", "body": {"mode":"raw","raw":"{\"bloquear\":true}"} } },
    { "name": "[Admin] Bitacora auditoria", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{access_token}}"}], "url": "{{base_url}}/admin/audit-logs" } },
    { "name": "Logout", "request": { "method": "POST", "header": [{"key":"Authorization","value":"Bearer {{access_token}}"}], "url": "{{base_url}}/auth/logout" } }
  ]
}
